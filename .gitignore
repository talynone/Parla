# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules

# Build outputs
dist
dist-ssr
*.local

# TypeScript incremental build cache
*.tsbuildinfo

# Environment
.env
.env.*
!.env.example

# Test coverage
coverage/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Secrets and signing keys - NEVER commit any of these
# Tauri auto-updater private key (generated by `tauri signer generate`)
# Authenticode code-signing certificates
*.key
*.pfx
*.p12
*.pem
.tauri/

# Model / audio / capture files that a contributor might drop in the
# repo while testing. The app stores these under %LOCALAPPDATA%, but
# if someone copies a model next to the code for convenience we don't
# want to accidentally commit a 2 GB .gguf or .onnx.
*.gguf
*.bin
*.onnx
*.wav
*.mp3
*.flac
*.ogg
